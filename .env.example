# Copy to .env.local and set a real value before deploying.
# Never commit .env.local — it's gitignored.

# 4-digit PIN gating /operator and /remote. Checked server-side only
# (app/api/auth/route.ts) — never sent to the client bundle. Falls back to
# 0065 if unset, which is fine for local development only.
#
# This is a convenience gate for a small trusted crew, not real
# authentication: no hashing, no rate limiting, no per-user accounts. See
# docs/DEPLOYMENT.md for what a production-grade version would add.
OPERATOR_PIN=0065

# Supabase project — see supabase/schema.sql for the tables these back and
# docs/ARCHITECTURE.md for why. Create a project at supabase.com, run
# schema.sql once in its SQL Editor, then copy these from
# Project Settings -> API.

# Project URL. Safe to expose to the client (NEXT_PUBLIC_) — Realtime and
# public reads use this.
NEXT_PUBLIC_SUPABASE_URL=

# anon public key. Safe to expose to the client — Row Level Security
# (supabase/schema.sql) restricts it to read-only on public tables.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role secret key. Server-only, used by API routes for writes —
# bypasses Row Level Security entirely. Never prefix with NEXT_PUBLIC_,
# never send to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Signs the operator session cookie set by app/api/auth/route.ts on a
# correct PIN. Any long random string; falls back to a dev-only default if
# unset, which is fine locally but must be set for a real deployment.
AUTH_COOKIE_SECRET=
